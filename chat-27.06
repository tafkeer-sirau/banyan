<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VillageConnect</title>
    
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

</head>

<body>

    <header>
        <div class="logo">
            <i class="fa-solid fa-tree"></i>
            VillageConnect
        </div>
        <nav>
            <a href="sample.html">Home</a>
            <a href="news.html">News</a>
            <a href="calendar.html">Calendar</a>
            <a href="about.html">About</a>
            <a href="contact.html">Contact</a>
        </nav>
    </header>

    <section class="hero">
        <h1>Connecting Every Village Together</h1>
        <p>A digital Banyan Tree where every voice matters.</p>
        <button>Join Community</button>
    </section>

    <div class="ticker">
        <div class="ticker-text">
            Farmer's Market Sunday | Tree Plantation Drive | Cricket Tournament | Water Supply Notice | Annual Village Fair
        </div>
    </div>

    <section class="cards">
        <div class="card">
            <i class="fa-solid fa-newspaper"></i>
            <h2>Village News</h2>
            <p>Daily local announcements.</p>
        </div>

        <div class="card">
            <i class="fa-solid fa-calendar-days"></i>
            <h2>Community Calendar</h2>
            <p>Festivals, fairs and meetings.</p>
        </div>

        <div class="card">
            <i class="fa-solid fa-microphone"></i>
            <h2>Voice-to-Text</h2>
            <p>Speak your thoughts instead of typing.</p>
            <button onclick="startSpeech()">Speak</button>
            <p id="speechOutput"></p>
        </div>

        <div class="card">
            <i class="fa-solid fa-users"></i>
            <h2>Community Forum</h2>
            <p>Share ideas with neighbours.</p>
        </div>
    </section>

    <footer>
        &copy; 2026 VillageConnect
    </footer>

    <script src="script.js"></script>

</body>
</html>
* {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background: #F7F4EA;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background: #556B2F;
            color: white;
        }

        nav a {
            color: white;
            margin-left: 20px;
            text-decoration: none;
        }

        .hero {
            text-align: center;
            padding: 90px 20px;
            background: #D8B25C;
            color: white;
        }

        .hero button {
            margin-top: 20px;
            padding: 12px 28px;
            border: none;
            background: #556B2F;
            color: white;
            cursor: pointer;
            border-radius: 8px;
        }

        .ticker {
            overflow: hidden;
            background: #7C4A2D;
            color: white;
            padding: 12px;
            white-space: nowrap;
        }

        .ticker-text {
            display: inline-block;
            padding-left: 100%;
            animation: move 18s linear infinite;
        }

        @keyframes move {
            0% {
                transform: translateX(0);
            }
            100% {
                transform: translateX(-100%);
            }
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 30px;
            padding: 40px;
        }

        .card {
            background: white;
            padding: 25px;
            text-align: center;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0, 0, 0, .15);
        }

        .card i {
            font-size: 45px;
            margin-bottom: 15px;
            color: #556B2F;
        }

        footer {
            background: #556B2F;
            color: white;
            text-align: center;
            padding: 20px;
        }
