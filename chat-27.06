async function cryptoHash(message) {
    // 1. Encode the string as raw UTF-8 bytes
    const msgBuffer = new TextEncoder().encode(message);                    

    // 2. Generate a SHA-256 hash buffer using native crypto
    const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
    
    // 3. Convert the ArrayBuffer to a readable Hexadecimal string
    const hashArray = Array.from(new Uint8Array(hashBuffer));                     
    const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
    
    return hashHex;
}

// Example Usage (Returns a Promise):
cryptoHash("hello").then(hash => console.log(hash)); 
// Output: "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824"
17:51
function simpleHash(str) {

    let hash = 5381; // Initial prime seed value

    

    for (let i = 0; i < str.length; i++) {

        // Equivalent to: hash = hash * 33 + charCode

        hash = ((hash << 5) + hash) + str.charCodeAt(i);

        hash |= 0; // Convert to a 32-bit signed integer

    }

    

    // Convert to an unsigned 32-bit integer and output as a base-36 string

    return (hash >>> 0).toString(36);

}



// Example Usage:

console.log(simpleHash("hello")); // Output: "4vk3a"

console.log(simpleHash("world")); // Output: "58mqu"

